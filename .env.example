# ── Database ─────────────────────────────────────────────────────────────────
# Render PostgreSQL internal URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# Same but sync (psycopg2) — used by alembic and the seed script
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=sys_api
JWT_AUDIENCE=pos-clients
JWT_TTL_SECONDS=28800

# ── RabbitMQ (CloudAMQP free tier) ────────────────────────────────────────────
RABBITMQ_URL=amqps://user:password@rabbit.cloudamqp.com/vhost

# ── Merchant / SRI ────────────────────────────────────────────────────────────
MERCHANT_RUC=1712345678001
MERCHANT_NAME=Micromercado El Vecino
MERCHANT_ADDRESS=Av. de los Shyris N34-12 y Eloy Alfaro
MERCHANT_OBLIGADO_CONTABILIDAD=SI

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
ENV=prod

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Render frontend URL)
CORS_ALLOW_ORIGINS=https://your-frontend.onrender.com

# ── Login policy ─────────────────────────────────────────────────────────────
LOGIN_MAX_FAILED_ATTEMPTS=3
